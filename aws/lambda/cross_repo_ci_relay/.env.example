# --- GitHub App / Webhook ---
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=

# [Lambda recommended] Load secrets from AWS Secrets Manager on cold start.
# If these are set, `lambda_function.py` will populate the corresponding env vars.
GITHUB_WEBHOOK_SECRET_SECRET_ARN=
GITHUB_APP_PRIVATE_KEY_SECRET_ARN=

# --- Relay ---
UPSTREAM_REPO=
WHITELIST_PATH=https://github.com/<owner>/<repo>/blob/<ref>/whitelist.yaml

# --- ClickHouse ---
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=

# [Lambda recommended] Alternative to CLICKHOUSE_PASSWORD.
CLICKHOUSE_PASSWORD_SECRET_ARN=

# --- Redis (whitelist cache) ---
REDIS_URL=
WHITELIST_TTL_SECONDS=

# [Optional] Alternative to REDIS_URL.
REDIS_URL_SECRET_ARN=
# --- Logging ---
LOG_LEVEL=