# GitHub App
GITHUB_APP_ID=123456

# Credentials: set directly OR provide SECRET_STORE_ARN (Secrets Manager)
GITHUB_APP_SECRET=your_webhook_secret_here
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# AWS Secrets Manager (alternative to the two vars above)
# SECRET_STORE_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:cross-repo-ci-relay/app-secrets-xxxxxx

# Redis (AWS ElastiCache)
REDIS_ENDPOINT=my-cache.xxxxxx.apse1.cache.amazonaws.com
# REDIS_LOGIN=default:your_password_here
# REDIS_TLS=true

# Allowlist
WHITELIST_URL=https://github.com/owner/repo/blob/main/path/to/allowlist.yaml
# WHITELIST_TTL_SECONDS=1200

# Upstream repository to relay webhooks from
# UPSTREAM_REPO=pytorch/pytorch

# Logging
# LOG_LEVEL=INFO
